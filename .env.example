# Clé API Google AI Studio (Gemini)
GEMINI_API_KEY=your_api_key_here

# Port du serveur (défaut: 3000)
PORT=3000

# Langues cibles pour la traduction (codes séparés par des virgules)
# Exemples: en,fr,es,pt,sw,ln
TARGET_LANGUAGES=en

# Nom de l'église (affiché sur l'interface publique)
CHURCH_NAME=Notre Église
